{
  "name": "D Flip-Flop (Master-Slave from NAND gates)",
  "description": "Master-slave D flip-flop built from cross-coupled NAND gates with inverted inputs instead of separate NOT gates.",
  "components": [
    { "id": "D",   "type": "In",   "props": { "label": "D" } },
    { "id": "CLK", "type": "In",   "props": { "label": "CLK" } },

    { "id": "G1",  "type": "NAnd" },
    { "id": "G2",  "type": "NAnd", "props": { "_inverterLabels": "1" } },
    { "id": "G3",  "type": "NAnd" },
    { "id": "G4",  "type": "NAnd" },

    { "id": "G5",  "type": "NAnd", "props": { "_inverterLabels": "2" } },
    { "id": "G6",  "type": "NAnd", "props": { "_inverterLabels": "2" } },
    { "id": "G7",  "type": "NAnd" },
    { "id": "G8",  "type": "NAnd" },

    { "id": "Q",   "type": "Out",  "props": { "label": "Q" } },
    { "id": "Qn",  "type": "Out",  "props": { "label": "Q̄" } }
  ],
  "connections": [
    ["D:out",   "G1:In_1"],
    ["D:out",   "G2:In_1"],
    ["CLK:out", "G1:In_2"],
    ["CLK:out", "G2:In_2"],
    ["CLK:out", "G5:In_2"],
    ["CLK:out", "G6:In_2"],

    ["G1:out",  "G3:In_1"],
    ["G2:out",  "G4:In_1"],
    ["G4:out",  "G3:In_2"],
    ["G3:out",  "G4:In_2"],

    ["G3:out",  "G5:In_1"],
    ["G4:out",  "G6:In_1"],

    ["G5:out",  "G7:In_1"],
    ["G6:out",  "G8:In_1"],
    ["G8:out",  "G7:In_2"],
    ["G7:out",  "G8:In_2"],

    ["G7:out",  "Q:in"],
    ["G8:out",  "Qn:in"]
  ]
}
