digraph "ngspice" {
  rankdir=TB;
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded"];
  edge [fontname="Helvetica", fontsize=8];
  compound=true;
  newrank=true;
  label="ngspice State Machine";
  labelloc=t;
  fontsize=16;

  subgraph cluster_dcop {
    label="DC Operating Point";
    style="rounded,filled";
    fillcolor="#bbdefb";
    color="#1565c0";
    fontcolor="#0d47a1";
    fontsize=12;

    dcop_entry [label="dcop entry", fillcolor="white"];
    cktop_initial_solve [label="cktop initial solve", fillcolor="white"];
    gmin_stepping [label="gmin stepping", fillcolor="white"];
    source_stepping [label="source stepping", fillcolor="white"];
    cktop_converged [label="cktop converged", fillcolor="white"];
    cktop_failed [label="cktop failed", fillcolor="white"];
    dcop_finalize [label="dcop finalize", fillcolor="white"];
    dcop_set_smsig_mode [label="dcop set smsig mode", fillcolor="white"];
    dcop_final_load [label="dcop final load", fillcolor="white"];
    dcop_output [label="dcop output", fillcolor="white"];
    dcop_failed [label="dcop failed", fillcolor="white"];
  }

  subgraph cluster_nr {
    label="Newton-Raphson";
    style="rounded,filled";
    fillcolor="#c8e6c9";
    color="#2e7d32";
    fontcolor="#1b5e20";
    fontsize=12;

    niiter_loop_entry [label="niiter loop entry", fillcolor="white"];
    niiter_check_uic_bypass [label="niiter check uic bypass", fillcolor="white"];
    niiter_uic_single_load [label="niiter uic single load", fillcolor="white"];
    niiter_check_reinit [label="niiter check reinit", fillcolor="white"];
    allocate_rhs_vectors [label="allocate rhs vectors", fillcolor="white"];
    clear_noncon_and_load [label="clear noncon and load", fillcolor="white"];
    cktload_devices [label="cktload devices", fillcolor="white"];
    apply_nodesets_and_ics [label="apply nodesets and ics", fillcolor="white"];
    preorder_matrix [label="preorder matrix", fillcolor="white"];
    lu_factorize_with_reorder [label="lu factorize with reorder", fillcolor="white"];
    lu_factorize_numerical [label="lu factorize numerical", fillcolor="white"];
    sparse_solve [label="sparse solve", fillcolor="white"];
    check_iteration_limit [label="check iteration limit", fillcolor="white"];
    check_node_convergence [label="check node convergence", fillcolor="white"];
    apply_newton_damping [label="apply newton damping", fillcolor="white"];
    check_initf_and_transition [label="check initf and transition", fillcolor="white"];
    transition_jct_to_fix [label="transition jct to fix", fillcolor="white"];
    transition_fix_to_float [label="transition fix to float", fillcolor="white"];
    transition_tran_to_float [label="transition tran to float", fillcolor="white"];
    transition_pred_to_float [label="transition pred to float", fillcolor="white"];
    transition_smsig_to_float [label="transition smsig to float", fillcolor="white"];
    swap_rhs_vectors [label="swap rhs vectors", fillcolor="white"];
    niiter_return_ok [label="niiter return ok", fillcolor="white"];
    niiter_return_iterlim [label="niiter return iterlim", fillcolor="white"];
    niiter_return_error [label="niiter return error", fillcolor="white"];
  }

  subgraph cluster_transient {
    label="Transient";
    style="rounded,filled";
    fillcolor="#ffe0b2";
    color="#e65100";
    fontcolor="#bf360c";
    fontsize=12;

    tran_init [label="tran init", fillcolor="white"];
    tran_compute_initial_delta [label="tran compute initial delta", fillcolor="white"];
    tran_apply_initial_conditions [label="tran apply initial conditions", fillcolor="white"];
    tran_dcop_entry [label="tran dcop entry", fillcolor="white"];
    tran_dcop_converged [label="tran dcop converged", fillcolor="white"];
    tran_dcop_failed [label="tran dcop failed", fillcolor="white"];
    tran_init_state_vectors [label="tran init state vectors", fillcolor="white"];
    tran_set_initial_mode [label="tran set initial mode", fillcolor="white"];
    tran_copy_state0_to_state1 [label="tran copy state0 to state1", fillcolor="white"];
    tran_accepted_timepoint [label="tran accepted timepoint", fillcolor="white"];
    tran_call_cktaccept [label="tran call cktaccept", fillcolor="white"];
    tran_output_data [label="tran output data", fillcolor="white"];
    tran_check_end_time [label="tran check end time", fillcolor="white"];
    tran_compute_next_delta [label="tran compute next delta", fillcolor="white"];
    tran_breakpoint_handling [label="tran breakpoint handling", fillcolor="white"];
    tran_rotate_state_vectors [label="tran rotate state vectors", fillcolor="white"];
    tran_advance_time [label="tran advance time", fillcolor="white"];
    tran_compute_integration_coefficients [label="tran compute integration coefficients", fillcolor="white"];
    tran_predict_solution [label="tran predict solution", fillcolor="white"];
    tran_call_niiter [label="tran call niiter", fillcolor="white"];
    tran_nr_converged [label="tran nr converged", fillcolor="white"];
    tran_set_initpred_mode [label="tran set initpred mode", fillcolor="white"];
    tran_firsttime_state_copy [label="tran firsttime state copy", fillcolor="white"];
    tran_check_firsttime_skip_lte [label="tran check firsttime skip lte", fillcolor="white"];
    tran_truncation_error_check [label="tran truncation error check", fillcolor="white"];
    tran_lte_accept [label="tran lte accept", fillcolor="white"];
    tran_lte_reject [label="tran lte reject", fillcolor="white"];
    tran_nr_failed [label="tran nr failed", fillcolor="white"];
    tran_nr_failed_reduce_delta [label="tran nr failed reduce delta", fillcolor="white"];
    tran_check_delmin [label="tran check delmin", fillcolor="white"];
    tran_set_delta_to_delmin [label="tran set delta to delmin", fillcolor="white"];
    tran_timestep_too_small [label="tran timestep too small", fillcolor="white"];
  }

  dcop_entry -> cktop_initial_solve [label="Call CKTop(ckt, MODEDCOP|MODEINITJCT, MODEDCOP|MO..."];
  cktop_initial_solve -> niiter_loop_entry [label="Call NIiter(ckt, iterlim) with firstmode"];
  cktop_initial_solve -> gmin_stepping [label="Go directly to gmin stepping"];
  gmin_stepping -> source_stepping [label="Gmin stepping failed, try source stepping"];
  gmin_stepping -> cktop_converged [label="Gmin stepping succeeded"];
  source_stepping -> cktop_converged [label="Source stepping succeeded"];
  source_stepping -> cktop_failed [label="Source stepping also failed"];
  cktop_converged -> dcop_finalize [label="Return to DCop"];
  cktop_converged -> tran_dcop_converged [label="Return to DCtran initial OP"];
  cktop_failed -> dcop_failed [label="Report failure"];
  cktop_failed -> tran_dcop_failed [label="Report failure"];
  niiter_loop_entry -> niiter_check_uic_bypass [label="Enter NIiter"];
  niiter_check_uic_bypass -> niiter_uic_single_load [label="UIC bypass: single load, no iteration"];
  niiter_check_uic_bypass -> niiter_check_reinit [label="Normal NR path"];
  niiter_uic_single_load -> niiter_return_ok [label="Return OK after single load"];
  niiter_check_reinit -> allocate_rhs_vectors [label="First call: allocate vectors"];
  niiter_check_reinit -> clear_noncon_and_load [label="Already initialized"];
  allocate_rhs_vectors -> clear_noncon_and_load [label="Vectors allocated, enter NR loop"];
  clear_noncon_and_load -> cktload_devices [label="Load devices"];
  cktload_devices -> apply_nodesets_and_ics [label="DC mode: apply nodesets/ICs after device load"];
  cktload_devices -> preorder_matrix [label="Transient: skip nodeset application"];
  apply_nodesets_and_ics -> preorder_matrix [label="Nodesets/ICs applied, continue to factorization"];
  preorder_matrix -> lu_factorize_with_reorder [label="Need full pivot reorder"];
  preorder_matrix -> lu_factorize_numerical [label="Reuse existing pivot order"];
  lu_factorize_with_reorder -> sparse_solve [label="Reorder + factor succeeded"];
  lu_factorize_with_reorder -> niiter_return_error [label="Matrix singular even after reorder"];
  lu_factorize_numerical -> sparse_solve [label="LU factorization succeeded"];
  lu_factorize_numerical -> clear_noncon_and_load [label="Singular: set NISHOULDREORDER, retry from top of ..."];
  lu_factorize_numerical -> niiter_return_error [label="Fatal factorization error"];
  sparse_solve -> check_iteration_limit [label="Solution vector computed"];
  check_iteration_limit -> niiter_return_iterlim [label="Too many iterations"];
  check_iteration_limit -> check_node_convergence [label="Within iteration limit"];
  check_node_convergence -> apply_newton_damping [label="Node convergence checked"];
  apply_newton_damping -> check_initf_and_transition [label="Damping applied (if needed)"];
  check_initf_and_transition -> niiter_return_ok [label="Converged in float mode -- NR done"];
  check_initf_and_transition -> swap_rhs_vectors [label="Not converged in float, iterate again"];
  check_initf_and_transition -> transition_jct_to_fix [label="Junction init done, switch to fix mode"];
  check_initf_and_transition -> transition_fix_to_float [label="Fix mode converged, switch to float"];
  check_initf_and_transition -> transition_tran_to_float [label="First tran iteration done, switch to float"];
  check_initf_and_transition -> transition_pred_to_float [label="Predictor done, switch to float"];
  check_initf_and_transition -> transition_smsig_to_float [label="Small-signal init done, switch to float"];
  transition_jct_to_fix -> swap_rhs_vectors [label="Continue NR with MODEINITFIX"];
  transition_fix_to_float -> swap_rhs_vectors [label="Continue NR with MODEINITFLOAT"];
  transition_tran_to_float -> swap_rhs_vectors [label="Continue NR with MODEINITFLOAT"];
  transition_pred_to_float -> swap_rhs_vectors [label="Continue NR with MODEINITFLOAT"];
  transition_smsig_to_float -> swap_rhs_vectors [label="Continue NR with MODEINITFLOAT"];
  swap_rhs_vectors -> clear_noncon_and_load [label="Back to top of NR loop"];
  niiter_return_ok -> cktop_converged [label="Return OK to CKTop"];
  niiter_return_ok -> tran_nr_converged [label="Return OK to DCtran"];
  niiter_return_iterlim -> cktop_failed [label="called from CKTop directly"];
  niiter_return_iterlim -> gmin_stepping [label="Triggers convergence aids"];
  niiter_return_iterlim -> tran_nr_failed [label="NR failed for this timepoint"];
  niiter_return_error -> cktop_failed [label="called from CKTop"];
  niiter_return_error -> tran_nr_failed [label="called from DCtran"];
  dcop_finalize -> dcop_set_smsig_mode [label="converged == 0"];
  dcop_set_smsig_mode -> dcop_final_load [label="always"];
  dcop_final_load -> dcop_output [label="always"];
  tran_init -> tran_compute_initial_delta [label="always"];
  tran_compute_initial_delta -> tran_apply_initial_conditions [label="Initial delta computed"];
  tran_apply_initial_conditions -> tran_dcop_entry [label="always"];
  tran_dcop_entry -> cktop_initial_solve [label="CKTop(ckt, MODETRANOP|MODEINITJCT, MODETRANOP|MOD..."];
  tran_dcop_converged -> tran_init_state_vectors [label="Initial OP found, prepare for transient"];
  tran_init_state_vectors -> tran_set_initial_mode [label="always"];
  tran_set_initial_mode -> tran_copy_state0_to_state1 [label="always"];
  tran_copy_state0_to_state1 -> tran_accepted_timepoint [label="Jump to nextTime (label 650)"];
  tran_accepted_timepoint -> tran_call_cktaccept [label="Accept this timepoint"];
  tran_call_cktaccept -> tran_output_data [label="always"];
  tran_output_data -> tran_check_end_time [label="always"];
  tran_check_end_time -> tran_compute_next_delta [label="Continue simulation"];
  tran_compute_next_delta -> tran_breakpoint_handling [label="always"];
  tran_breakpoint_handling -> tran_rotate_state_vectors [label="Delta finalized, prepare for NR"];
  tran_rotate_state_vectors -> tran_advance_time [label="Enter inner retry loop (label 600)"];
  tran_advance_time -> tran_compute_integration_coefficients [label="always"];
  tran_compute_integration_coefficients -> tran_predict_solution [label="PREDICTOR defined"];
  tran_compute_integration_coefficients -> tran_call_niiter [label="PREDICTOR not defined (standard)"];
  tran_predict_solution -> tran_call_niiter [label="always"];
  tran_call_niiter -> niiter_loop_entry [label="NIiter(ckt, CKTtranMaxIter)"];
  tran_nr_converged -> tran_set_initpred_mode [label="always"];
  tran_set_initpred_mode -> tran_firsttime_state_copy [label="First timepoint: copy states"];
  tran_set_initpred_mode -> tran_truncation_error_check [label="Check LTE"];
  tran_set_initpred_mode -> tran_check_firsttime_skip_lte [label="always"];
  tran_firsttime_state_copy -> tran_check_firsttime_skip_lte [label="always"];
  tran_check_firsttime_skip_lte -> tran_accepted_timepoint [label="First timepoint always accepted"];
  tran_check_firsttime_skip_lte -> tran_truncation_error_check [label="Check LTE before accepting"];
  tran_truncation_error_check -> tran_lte_accept [label="LTE OK, accept step"];
  tran_truncation_error_check -> tran_lte_reject [label="LTE too large, reject step"];
  tran_lte_accept -> tran_accepted_timepoint [label="goto nextTime (label 650)"];
  tran_lte_reject -> tran_check_delmin [label="Reject step, reduce delta"];
  tran_nr_failed -> tran_nr_failed_reduce_delta [label="NR failed, reduce timestep"];
  tran_nr_failed_reduce_delta -> tran_check_delmin [label="always"];
  tran_check_delmin -> tran_advance_time [label="Delta still above minimum, retry"];
  tran_check_delmin -> tran_set_delta_to_delmin [label="Try one more time at delmin"];
  tran_check_delmin -> tran_timestep_too_small [label="Already tried delmin, give up"];
  tran_set_delta_to_delmin -> tran_advance_time [label="Retry with delta = delmin"];
}