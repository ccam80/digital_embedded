  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node scripts/run-all-tests.mjs",
    "test:q": "node scripts/run-all-tests.mjs -q",
    "test:watch": "vitest",
    "lint": "eslint src",
