          "label": "sw",
          "model": "behavioral",
          "rOn": 1,
          "rOff": 1000000000,
          "vThreshold": 1.65,
          "vHysteresis": 0
        },
        "rotation": 0,
        "type": "SwitchSPDT"
      },
      {
