{
  "circuit": {
    "description": "SPDT switch NC path closed: VCC=5V through R_load=1kΩ into sw:com; sw:nc to GND; sw:no floating via R_no=1MΩ to GND; V_ctrl=0V < vThreshold=1.65V (COM-NO open, COM-NC closed). Cat 3/5 transient parity vs ngspice.",
    "elements": [
      {
        "id": "sw-spdt-nc-vcc",
        "position": { "x": 0, "y": 0 },
        "properties": { "_modelParams": { "voltage": 5 }, "label": "vcc", "voltage": 5 },
        "rotation": 0,
        "type": "DcVoltageSource"
      },
      {
