{
  "circuit": {
    "description": "2kHz square AcVoltageSource (amplitude=1.65 + dcOffset=1.65 = 0V to 3.3V swing, riseTime/fallTime=1ns) driving an RC low-pass (R=10k, C=1uF, tau=10ms). Half-period 0.25ms is much shorter than tau so the cap voltage ramps continuously while the source toggles. Replaces clock-canon-2khz-rc.dts; AcVoltageSource is the ngspice-parity-clean analog square-wave primitive.",
    "elements": [
      {
        "id": "v1-2khz-square",
        "position": { "x": 0, "y": 2 },
        "properties": {
          "_modelParams": {
            "amplitude": 1.65,
            "dcOffset": 1.65,
            "fallTime": 1e-9,
            "frequency": 2000,
            "phase": 0,
            "riseTime": 1e-9
          },
          "amplitude": 1.65,
          "dcOffset": 1.65,
          "frequency": 2000,
          "label": "V1",
          "phase": 0,
          "waveform": "square"
        },
        "rotation": 0,
        "type": "AcVoltageSource"
      },
      {
        "id": "r1-10k",
