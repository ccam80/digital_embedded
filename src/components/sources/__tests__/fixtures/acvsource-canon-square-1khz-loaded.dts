{
  "circuit": {
    "description": "1kHz square AcVoltageSource (amplitude=1.65 + dcOffset=1.65 = 0V to 3.3V swing, riseTime/fallTime=1ns) driving a 1k load to ground. Replaces clock-canon-1khz-loaded.dts; AcVoltageSource is the ngspice-parity-clean analog square-wave primitive (the digital Clock component cannot achieve bit-exact PULSE parity due to ngspice vsrcload.c:81-86 CKTstep substitution on TR=0).",
    "elements": [
      {
        "id": "v1-1khz-square",
        "position": { "x": 0, "y": 2 },
        "properties": {
          "_modelParams": {
            "amplitude": 1.65,
            "dcOffset": 1.65,
            "fallTime": 1e-9,
            "frequency": 1000,
            "phase": 0,
            "riseTime": 1e-9
          },
          "amplitude": 1.65,
          "dcOffset": 1.65,
          "frequency": 1000,
          "label": "V1",
          "phase": 0,
          "waveform": "square"
        },
        "rotation": 0,
        "type": "AcVoltageSource"
      },
      {
        "id": "r1-load",
        "position": { "x": 12, "y": 1 },
        "properties": {
          "_modelParams": { "resistance": 1000 },
          "label": "R1",
          "resistance": 1000
        },
        "rotation": 0,
        "type": "Resistor"
      },
      {
        "id": "gnd",
        "position": { "x": 24, "y": 1 },
        "properties": { "label": "gnd" },
        "rotation": 0,
        "type": "Ground"
      }
    ],
    "name": "acvsource-canon-square-1khz-loaded",
    "wires": [
      { "points": [{ "x": 4, "y": 2 }, { "x": 8, "y": 2 }] },
      { "points": [{ "x": 8, "y": 2 }, { "x": 8, "y": 1 }] },
      { "points": [{ "x": 8, "y": 1 }, { "x": 12, "y": 1 }] },
      { "points": [{ "x": 16, "y": 1 }, { "x": 24, "y": 1 }] },
      { "points": [{ "x": 0, "y": 2 }, { "x": 0, "y": 5 }] },
      { "points": [{ "x": 0, "y": 5 }, { "x": 24, "y": 5 }] },
      { "points": [{ "x": 24, "y": 5 }, { "x": 24, "y": 1 }] }
    ]
  },
  "format": "dts",
  "version": 1
}
