            },
            "layout": {
              "col": 1,
              "row": 0
            }
          },
          {
            "id": "A2",
            "type": "NAnd",
            "props": {
              "label": "A2"
            },
            "layout": {
              "col": 1,
              "row": 1
            }
          },
          {
            "id": "G1",
