    <visualElement>
      <elementName>Testcase</elementName>
      <elementAttributes>
        <entry>
          <string>Testdata</string>
          <testData>
            <dataString>C A0 A1 D !W R  D_O

loop (B, 2)
  loop (D, 2)

    0 (B) (D) 0 0 0   0
    C (B) (D) 0 0 0   0
    C (B) (D) X 1 1   0
    C (B) (D) X 1 1   0
    C (B) (D) 0 0 1   0

    loop (A, 256)
      C (B) (D) (A)  0 0  0
      C (B) (D)  X   1 1 (A)
    end loop
  end loop
end loop
</dataString>
          </testData>
        </entry>
      </elementAttributes>
      <pos x="1620" y="-120"/>
    </visualElement>
