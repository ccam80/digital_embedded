<circuit>
  <version>2</version>
  <attributes>
    <entry>
      <string>Description</string>
      <string>Single 8-bit register. D_O port has an internal buffer so should be connectable to the input bus.</string>
    </entry>
    <entry>
      <string>romContent</string>
      <romList>
        <roms/>
      </romList>
    </entry>
