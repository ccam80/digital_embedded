    <visualElement>
      <elementName>Testcase</elementName>
      <elementAttributes>
        <entry>
          <string>Testdata</string>
          <testData>
            <dataString>C A D !W R  D_O

loop (B, 4)
  

    0 (B) 0 0 0   0
    C (B) 0 0 0   0
    C (B) X 1 1   0
    C (B) X 1 1   0
    C (B) 0 0 1   0

    loop (E, 256)
      C (B) (E)  0 0  0
      C (B)  X   1 1 (E)
    end loop
end loop
</dataString>
          </testData>
        </entry>
      </elementAttributes>
