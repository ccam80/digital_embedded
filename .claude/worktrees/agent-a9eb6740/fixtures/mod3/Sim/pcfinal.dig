<?xml version="1.0" encoding="utf-8"?>
<circuit>
  <version>2</version>
  <attributes>
    <entry>
      <string>Description</string>
      <string>Program Counter for 10-bit program memory

Incorporates a program counter register and branching logic.

Inputs:

C	Clock
R	Reset register to 0
jump[10]	Increment or absolute address to branch to
rel	PC is incremented by jump if rel is high
abs	PC is loaded with jump if abs is high (if rel and abs are high, abs wins)

Outputs:

PC[10]	Current instruction address
NEXT[10]	PC + 1 (next address if no branch)</string>
    </entry>
    <entry>
      <string>Label</string>
      <string>PC</string>
    </entry>
    <entry>
      <string>romContent</string>
      <romList>
        <roms/>
      </romList>
    </entry>
    <entry>
      <string>Width</string>
      <int>5</int>
    </entry>
  </attributes>
