    <visualElement>
      <elementName>Testcase</elementName>
      <elementAttributes>
        <entry>
          <string>Testdata</string>
          <testData>
            <dataString>Ci IN  OUT Co
loop(A,128)
  0 (A) (A*2) 0
  1 (A) (A*2 + 1) 0
  0 (A+128) (A*2) 1
  1 (A+128) (A*2+1) 1
end loop</dataString>
          </testData>
        </entry>
      </elementAttributes>
      <pos x="400" y="0"/>
    </visualElement>
    <visualElement>
      <elementName>In</elementName>
      <elementAttributes>
        <entry>
          <string>Label</string>
          <string>Ci</string>
        </entry>
      </elementAttributes>
      <pos x="260" y="80"/>
    </visualElement>
    <visualElement>
